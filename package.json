{
  "name": "local-hd-video-downloader",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node local/server.mjs",
    "dev": "node --watch local/server.mjs",
    "build": "node --check local/server.mjs && node --check local/downloaders.mjs && node --check web/app.js",
    "test": "vitest run --config vitest.config.mjs",
    "test:coverage": "vitest run --coverage --config vitest.config.mjs"
  },
  "dependencies": {
    "cors": "2.8.6",
    "express": "5.2.1",
    "ffmpeg-static": "5.3.0",
    "ffprobe-static": "3.1.0",
    "node-fetch": "3.3.2",
    "playwright": "1.61.1",
    "proxy-agent": "8.0.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "vitest": "4.1.10"
  },
  "type": "module"
}
